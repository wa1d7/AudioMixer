<Window x:Class="AuraMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aura Audio Mixer" Height="450" Width="800"
        Background="#0f172a" WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <UniformGrid Columns="5" Margin="20">
        
        <Border Background="#1e293b" Margin="8" CornerRadius="12" Padding="15">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CH 1" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtVol0" Text="0%" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15"/>
                    <TextBlock x:Name="TxtRaw0" Text="Raw: 0" Foreground="#64748b" FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="#1e293b" Margin="8" CornerRadius="12" Padding="15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="CH 2" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtVol1" Text="0%" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15"/>
                <TextBlock x:Name="TxtRaw1" Text="Raw: 0" Foreground="#64748b" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Background="#1e293b" Margin="8" CornerRadius="12" Padding="15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="CH 3" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtVol2" Text="0%" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15"/>
                <TextBlock x:Name="TxtRaw2" Text="Raw: 0" Foreground="#64748b" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Background="#1e293b" Margin="8" CornerRadius="12" Padding="15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="CH 4" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtVol3" Text="0%" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15"/>
                <TextBlock x:Name="TxtRaw3" Text="Raw: 0" Foreground="#64748b" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Background="#1e293b" Margin="8" CornerRadius="12" Padding="15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="CH 5" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtVol4" Text="0%" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15"/>
                <TextBlock x:Name="TxtRaw4" Text="Raw: 0" Foreground="#64748b" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </UniformGrid>
</Window>